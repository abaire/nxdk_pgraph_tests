<codeline lineno="74"><highlight class="normal"><sp/><sp/>Light::Commit(host);</highlight></codeline>
<codeline lineno="75"><highlight class="normal"></highlight></codeline>
<codeline lineno="76"><highlight class="normal"><sp/><sp/>XboxMath::vector_t<sp/>transformed_position;</highlight></codeline>
<codeline lineno="77"><highlight class="normal"><sp/><sp/>XboxMath::VectorMultMatrix(position_,<sp/>host.GetFixedFunctionModelViewMatrix(),<sp/>transformed_position);</highlight></codeline>
